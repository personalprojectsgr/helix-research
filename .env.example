PORT=6767
NODE_ENV=development

TRACKING_ENABLED=false
FB_PIXEL_ID=
FB_ACCESS_TOKEN=
FB_TEST_EVENT_CODE=

STORE_NAME="Helix Research"
STORE_DOMAIN=localhost
STORE_CURRENCY=USD

LOG_LEVEL=info

# Plisio crypto checkout (https://plisio.net)
# 1. Sign up + create a "Site" in API section, copy the Secret Key here.
# 2. For real webhook delivery in dev, run a tunnel (ngrok / cloudflared) and put the public URL in PLISIO_PUBLIC_BASE_URL.
#    Without a tunnel the polling fallback handles status updates locally.
# 3. Plisio uses ONE key for both the API and the webhook HMAC; keep both vars set to the same value.
PLISIO_API_KEY=
PLISIO_SECRET_KEY=
PLISIO_INVOICE_EXPIRE_MIN=30
PLISIO_PUBLIC_BASE_URL=
