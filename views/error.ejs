    <span class="kicker kicker-rule text-rose">§ <%= code %></span>
  </div>
  <div class="col-span-12 lg:col-span-10">
    <h1 class="display-xl text-balance"><%= title %><span class="font-display-italic text-ink-3">.</span></h1>
