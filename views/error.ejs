    <div class="mt-10 flex gap-3 flex-wrap">
      <a href="/" class="btn btn-primary">Back to home →</a>
      <a href="/shop" class="btn btn-secondary">Open the catalog</a>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
