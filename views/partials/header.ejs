<div class="bg-ink text-paper text-[0.72rem] font-mono">
  <div class="max-w-editorial mx-auto px-5 sm:px-8 py-2 flex items-center justify-between gap-4 tracking-wider uppercase">
    <p class="flex items-center gap-2 opacity-80"><span class="dot dot-emerald"></span> Ships from EU · 2–7 days · plain unmarked outer</p>
    <div class="hidden md:flex items-center gap-5 opacity-70">
      <span>Free EU shipping &gt; $250</span>
      <span class="opacity-50">/</span>
      <span>Crypto-only · privacy-respecting</span>
    </div>
  </div>
</div>

<header class="sticky top-0 z-40 bg-paper/90 backdrop-blur-md border-b border-rule">
  <div class="max-w-editorial mx-auto px-5 sm:px-8 py-4 flex items-center gap-6">
    <a href="/" class="shrink-0 flex items-baseline gap-1" aria-label="Helix Research home">
      <span class="font-display text-[1.5rem] sm:text-[1.65rem] leading-none font-medium tracking-tight">Helix</span>
      <span class="font-display-italic text-[0.95rem] text-ink-3 leading-none">Research</span>
    </a>

    <nav class="hidden lg:flex items-center gap-7 ml-8 text-[0.85rem]">
      <a href="/shop" class="link-underline border-b-0 hover:border-b-[1px] pb-px">Catalog</a>
      <div class="relative group">
        <button type="button" class="flex items-center gap-1 hover:text-cobalt transition-colors">
          Categories <i data-lucide="chevron-down" class="w-3.5 h-3.5 opacity-60"></i>
        </button>
        <div class="absolute top-full -left-4 pt-4 w-[640px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
          <div class="bg-paper border border-rule shadow-lg p-1 grid grid-cols-2">
            <% catalog.categories.forEach((c) => { %>
              <a href="/category/<%= c.id %>" class="flex flex-col gap-0.5 px-5 py-4 hover:bg-paper-2 transition-colors border-b border-rule">
                <span class="kicker" style="color: <%= c.accent %>;"><%= c.short %></span>
                <span class="font-display text-[1.05rem] font-medium text-ink mt-1 leading-tight"><%= c.name %></span>
                <span class="text-[0.78rem] text-ink-4 mt-0.5 line-clamp-1"><%= c.blurb %></span>
              </a>
            <% }) %>
          </div>
        </div>
      </div>
      <a href="/about" class="hover:text-cobalt transition-colors">The Lab</a>
      <a href="/quality" class="hover:text-cobalt transition-colors">Quality</a>
      <a href="/shipping" class="hover:text-cobalt transition-colors">Shipping</a>
      <a href="/blog" class="hover:text-cobalt transition-colors">Journal</a>
      <a href="/faq" class="hover:text-cobalt transition-colors">FAQ</a>
    </nav>

    <div class="ml-auto flex items-center gap-1 sm:gap-2">
      <button type="button" id="search-toggle" class="w-10 h-10 grid place-items-center hover:bg-paper-2 transition-colors" aria-label="Search">
        <i data-lucide="search" class="w-[18px] h-[18px]"></i>
      </button>
      <a href="/cart" id="cart-trigger" class="relative w-10 h-10 grid place-items-center hover:bg-paper-2 transition-colors" aria-label="Cart">
        <i data-lucide="shopping-bag" class="w-[18px] h-[18px]"></i>
        <span id="cart-count-badge" class="absolute top-1 right-1 hidden min-w-[16px] h-[16px] px-1 bg-ink text-paper text-[10px] font-mono font-medium leading-[16px] text-center">0</span>
      </a>
      <button type="button" id="mobile-menu-btn" class="lg:hidden w-10 h-10 grid place-items-center hover:bg-paper-2 transition-colors" aria-label="Menu">
        <i data-lucide="menu" class="w-[18px] h-[18px]"></i>
      </button>
    </div>
  </div>

  <div id="search-bar" class="hidden border-t border-rule bg-paper">
    <form action="/shop" method="get" class="max-w-editorial mx-auto px-5 sm:px-8 py-4 flex items-center gap-4" role="search">
      <i data-lucide="search" class="w-5 h-5 text-ink-4 shrink-0"></i>
      <input type="search" name="q" placeholder="Search by compound, mechanism, or research area…" aria-label="Search peptides" class="flex-1 bg-transparent border-none outline-none text-base placeholder:text-ink-5" autofocus />
      <button type="submit" class="kicker text-cobalt hover:text-ink transition-colors">Search →</button>
    </form>
  </div>

  <div id="mobile-menu" class="lg:hidden hidden border-t border-rule bg-paper">
    <nav class="max-w-editorial mx-auto px-5 sm:px-8 py-3 flex flex-col text-[0.95rem]">
      <a href="/shop" class="py-3 border-b border-rule font-medium">Catalog</a>
      <details class="py-1 border-b border-rule">
        <summary class="py-3 font-medium cursor-pointer flex items-center justify-between list-none">Categories <i data-lucide="chevron-down" class="w-4 h-4"></i></summary>
        <div class="pb-3 grid grid-cols-1">
          <% catalog.categories.forEach((c) => { %>
            <a href="/category/<%= c.id %>" class="py-2.5 flex items-center justify-between border-t border-rule">
              <span class="font-display text-[1rem]"><%= c.name %></span>
              <span class="kicker" style="color: <%= c.accent %>;"><%= c.short %></span>
            </a>
          <% }) %>
        </div>
      </details>
      <a href="/about" class="py-3 border-b border-rule font-medium">The Lab</a>
      <a href="/quality" class="py-3 border-b border-rule font-medium">Quality</a>
      <a href="/shipping" class="py-3 border-b border-rule font-medium">Shipping</a>
      <a href="/blog" class="py-3 border-b border-rule font-medium">Journal</a>
      <a href="/faq" class="py-3 border-b border-rule font-medium">FAQ</a>
      <a href="/contact" class="py-3 font-medium">Contact</a>
    </nav>
  </div>
</header>
