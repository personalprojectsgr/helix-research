<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="max-w-editorial mx-auto px-5 sm:px-8 py-20 sm:py-32 grid grid-cols-12 gap-x-6 gap-y-10"
      data-order-id="<%= order.id %>"
      data-order-status="<%= order.status %>"
      data-order-total="<%= order.totalUsd %>"
      data-order-currency="<%= order.payment.sourceCurrency || 'USD' %>"
      data-purchase-event-id="<%= order.tracking.eventIds.purchase || '' %>">

  <div class="col-span-12 lg:col-span-2">
    <span id="kicker-status" class="kicker kicker-rule <%= order.status === 'paid' ? 'text-emerald' : 'text-ink-3' %>">
      § <%= order.status === 'paid' ? 'Confirmed' : 'Awaiting payment' %>
    </span>
  </div>

  <div class="col-span-12 lg:col-span-7">
    <h1 id="success-headline" class="display-xl text-balance">
      <% if (order.status === 'paid') { %>
        Thank you<span class="font-display-italic text-ink-3">,</span><br>your order is in.
      <% } else { %>
        Confirming<span class="font-display-italic text-ink-3"> </span><br>your payment.
      <% } %>
    </h1>
    <p id="success-lede" class="mt-8 lede">
      <% if (order.status === 'paid') { %>
        A confirmation email is on its way. The Certificate of Analysis ships with your order.
      <% } else { %>
        We're waiting for the blockchain to confirm your transaction. This page will update automatically — usually within a few minutes.
      <% } %>
    </p>

    <div class="mt-12 border border-ink p-6 sm:p-8 max-w-xl">
      <div class="flex items-center justify-between rule-b pb-4">
        <span class="kicker">Order ID</span>
        <span id="status-chip" class="chip <%= order.status === 'paid' ? 'evidence-fda' : 'evidence-mech' %>">
          <%= order.status === 'paid' ? 'Paid' : 'Pending' %>
        </span>
      </div>
      <p class="font-mono text-[1.4rem] sm:text-[1.7rem] font-medium tracking-tight mt-5 leading-none break-all"><%= order.id %></p>

      <% if (order.payment.cryptoCurrency) { %>
      <div class="mt-6 grid grid-cols-2 gap-x-5 gap-y-3 font-mono text-[0.78rem] uppercase tracking-wider text-ink-4">
        <div>
          <span class="block text-[0.65rem] text-ink-5">Amount</span>
          <span class="block text-ink text-[0.95rem] mt-1 normal-case tracking-normal font-medium">
            <%= order.payment.cryptoAmount || '—' %> <%= order.payment.cryptoCurrency %>
          </span>
        </div>
        <div>
          <span class="block text-[0.65rem] text-ink-5">Equivalent</span>
          <span class="block text-ink text-[0.95rem] mt-1 normal-case tracking-normal font-medium">
            $<%= Number(order.totalUsd).toFixed(2) %> USD
          </span>
        </div>
      </div>
      <% } %>

      <div id="order-line-items" class="mt-6 rule-t pt-5">
        <% (order.items || []).forEach(function(it) { %>
        <div class="flex items-center justify-between gap-3 py-2 border-t border-rule first:border-t-0">
          <span class="truncate">
            <span class="font-mono text-ink-4 text-[0.78rem] mr-2">×<%= it.qty %></span>
            <%= it.name %>
          </span>
          <span class="font-mono shrink-0 text-[0.85rem]">$<%= Number(it.lineTotal).toFixed(2) %></span>
        </div>
        <% }) %>
        <div class="flex items-center justify-between font-display text-[1.1rem] font-medium pt-4 mt-4 border-t border-ink">
          <span>Total</span>
          <span class="font-mono">$<%= Number(order.totalUsd).toFixed(2) %></span>
        </div>
      </div>
    </div>

    <% if (order.status !== 'paid' && order.payment.invoiceUrl) { %>
    <div id="pending-actions" class="mt-8 flex flex-wrap gap-3">
      <a href="<%= order.payment.invoiceUrl %>" target="_blank" rel="noopener" class="btn btn-secondary">
        <i data-lucide="external-link" class="w-4 h-4 mr-2"></i> Reopen invoice
      </a>
    </div>
    <% } %>

    <div id="paid-actions" class="mt-10 flex flex-wrap gap-3" <%= order.status !== 'paid' ? 'hidden' : '' %>>
      <a href="/shop" class="btn btn-primary">Continue browsing →</a>
      <a href="/" class="btn btn-secondary">Back to home</a>
    </div>
  </div>

  <aside class="col-span-12 lg:col-span-3 lg:pt-2 space-y-8">
    <div class="rule-t pt-6">
      <p class="kicker mb-3">Cold-chain</p>
      <p class="text-[0.92rem] text-ink-3 leading-relaxed">Insulated packaging keeps peptides at lab temperature during transit.</p>
    </div>
    <div class="rule-t pt-6">
      <p class="kicker mb-3">COA</p>
      <p class="text-[0.92rem] text-ink-3 leading-relaxed">Batch-specific Certificate of Analysis ships with every order.</p>
    </div>
    <div class="rule-t pt-6">
      <p class="kicker mb-3">Crypto</p>
      <p class="text-[0.92rem] text-ink-3 leading-relaxed">Settled on-chain via Plisio. Refunds are out-of-band — contact us with your order ID.</p>
    </div>
  </aside>
</main>

<%- include('partials/cart-drawer') %>
<%- include('partials/footer') %>
<%- include('partials/scripts') %>
