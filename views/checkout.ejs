<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="max-w-editorial mx-auto px-5 sm:px-8 pt-6 sm:pt-12 pb-32 lg:pb-20"
      data-plisio-enabled="<%= !!locals.plisioEnabled %>"
      data-free-shipping-threshold="<%= freeShippingThreshold %>">

  <div class="trust-strip border-y border-rule mb-10">
    <div><i data-lucide="truck"></i> Ships from EU</div>
    <div><i data-lucide="package-2"></i> Plain unmarked outer</div>
    <div><i data-lucide="shield-check"></i> Tracked end-to-end</div>
    <div><i data-lucide="bitcoin"></i> Crypto · no card data</div>
  </div>

  <div class="grid grid-cols-12 gap-x-6 gap-y-10">

    <div class="col-span-12 lg:col-span-2">
      <a href="/cart" class="kicker text-ink-3 hover:text-ink"><i data-lucide="arrow-left" class="w-3 h-3 inline"></i> Cart</a>
      <h1 class="display-md mt-4">Check<span class="font-display-italic">out</span>.</h1>
    </div>

    <div class="col-span-12 lg:col-span-7">

      <% if (!locals.plisioEnabled) { %>
      <div class="border border-rose px-6 py-5 bg-rose-soft text-ink mb-8">
        <p class="font-display text-[1.1rem] font-medium leading-snug">Crypto checkout is currently unavailable.</p>
        <p class="text-[0.9rem] text-ink-3 mt-2">
          Set <code class="font-mono text-[0.82rem] bg-paper-3 px-1.5 py-0.5">PLISIO_API_KEY</code> in <code class="font-mono text-[0.82rem] bg-paper-3 px-1.5 py-0.5">.env</code> and restart.
        </p>
      </div>
      <% } %>

      <form id="checkout-form" novalidate>

        <section class="grid grid-cols-12 gap-x-5 gap-y-4 pb-8 mb-8 rule-b">
          <div class="col-span-12 md:col-span-4 mb-2 md:mb-0">
            <span class="kicker text-ink-4">01</span>
            <h2 class="display-sm mt-2">Contact</h2>
            <p class="text-[0.85rem] text-ink-3 mt-2 leading-relaxed">Order updates and tracking — no marketing.</p>
          </div>
          <div class="col-span-12 md:col-span-8 grid grid-cols-2 gap-x-5 gap-y-5">
            <label class="block col-span-2">
              <span class="label">Email</span>
              <input type="email" name="email" required class="input" placeholder="researcher@institution.edu" autocomplete="email" />
            </label>
          </div>
        </section>

        <section class="grid grid-cols-12 gap-x-5 gap-y-4 pb-8 mb-8 rule-b">
          <div class="col-span-12 md:col-span-4 mb-2 md:mb-0">
            <span class="kicker text-ink-4">02</span>
            <h2 class="display-sm mt-2">Delivery</h2>
            <p class="text-[0.85rem] text-ink-3 mt-2 leading-relaxed">Plain unmarked outer. Return label uses a generic fulfilment ID.</p>
          </div>
          <div class="col-span-12 md:col-span-8 grid grid-cols-2 gap-x-5 gap-y-5">
            <label class="block col-span-2">
              <span class="label">Country / Region <span id="eta-pill-mount" class="float-right"></span></span>
              <select name="country" id="country-select" class="input" required>
                <option value="">Select country…</option>
                <optgroup label="European Union — Priority (2–3 days)">
                  <% shippingCountries.filter(c => c.zoneId === 'EU_PRIORITY').forEach(c => { %>
                    <option value="<%= c.code %>"><%= c.name %></option>
                  <% }) %>
                </optgroup>
                <optgroup label="European Union — Standard (3–5 days)">
                  <% shippingCountries.filter(c => c.zoneId === 'EU_STANDARD').forEach(c => { %>
                    <option value="<%= c.code %>"><%= c.name %></option>
                  <% }) %>
                </optgroup>
                <optgroup label="EU & Nordics (4–7 days)">
                  <% shippingCountries.filter(c => c.zoneId === 'EU_NORDIC').forEach(c => { %>
                    <option value="<%= c.code %>"><%= c.name %></option>
                  <% }) %>
                </optgroup>
                <optgroup label="UK / Switzerland / Norway (4–7 days)">
                  <% shippingCountries.filter(c => c.zoneId === 'UK_CH_NO').forEach(c => { %>
                    <option value="<%= c.code %>"><%= c.name %></option>
                  <% }) %>
                </optgroup>
                <optgroup label="International (7–14 days)">
                  <% shippingCountries.filter(c => c.zoneId === 'INTL').forEach(c => { %>
                    <option value="<%= c.code %>"><%= c.name %></option>
                  <% }) %>
                </optgroup>
              </select>
            </label>

            <label class="block"><span class="label">First name</span><input type="text" name="firstName" required class="input" autocomplete="given-name" /></label>
            <label class="block"><span class="label">Last name</span><input type="text" name="lastName" required class="input" autocomplete="family-name" /></label>
            <label class="block col-span-2"><span class="label">Address</span><input type="text" name="address" required class="input" autocomplete="street-address" placeholder="Street, building, apartment" /></label>
            <label class="block"><span class="label">City</span><input type="text" name="city" required class="input" autocomplete="address-level2" /></label>
            <label class="block"><span class="label">Postcode</span><input type="text" name="zip" required class="input" autocomplete="postal-code" /></label>
            <label class="block col-span-2"><span class="label">Phone (for carrier — optional)</span><input type="tel" name="phone" class="input" placeholder="+49 30 12345678" autocomplete="tel" /></label>
            <label class="block col-span-2"><span class="label">Institution / Lab (optional)</span><input type="text" name="institution" class="input" autocomplete="organization" /></label>
          </div>
        </section>

        <section class="grid grid-cols-12 gap-x-5 gap-y-4 pb-8 mb-8 rule-b">
          <div class="col-span-12 md:col-span-4 mb-2 md:mb-0">
            <span class="kicker text-ink-4">03</span>
            <h2 class="display-sm mt-2">Method</h2>
            <p class="text-[0.85rem] text-ink-3 mt-2 leading-relaxed">Cold-chain insulated packaging. Tracking emailed on dispatch.</p>
          </div>
          <div class="col-span-12 md:col-span-8 space-y-2.5" id="shipping-options-mount">
            <p class="text-[0.85rem] text-ink-4 italic">Select a country above to see delivery options.</p>
          </div>
        </section>

        <section class="grid grid-cols-12 gap-x-5 gap-y-4 pb-8 mb-8">
          <div class="col-span-12 md:col-span-4 mb-2 md:mb-0">
            <span class="kicker text-ink-4">04</span>
            <h2 class="display-sm mt-2">Payment</h2>
            <p class="text-[0.85rem] text-ink-3 mt-2 leading-relaxed">Settled on-chain. We never touch a card or bank account.</p>
          </div>
          <div class="col-span-12 md:col-span-8">
            <div class="border border-ink p-6">
              <div class="flex items-center justify-between gap-3 mb-3">
                <span class="flex items-center gap-3"><i data-lucide="bitcoin" class="w-5 h-5"></i><span class="font-display text-[1.1rem] font-medium">Cryptocurrency</span></span>
                <span class="kicker text-ink-4">via Plisio</span>
              </div>
              <p class="text-[0.92rem] text-ink-3 leading-relaxed mb-5">
                Pay in <strong class="text-ink">BTC, ETH, USDT, USDC, LTC, SOL, XMR, TON, TRX, DOGE</strong> or any coin supported by your wallet. Your invoice locks the rate at creation and expires in 30 minutes — retry anytime.
              </p>
              <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1.5 text-[0.7rem] font-mono uppercase tracking-wider text-ink-4">
                <li><span class="dot dot-emerald mr-2"></span>0.5% network fee</li>
                <li><span class="dot dot-emerald mr-2"></span>No card data stored</li>
                <li><span class="dot dot-emerald mr-2"></span>Privacy-respecting</li>
                <li><span class="dot dot-emerald mr-2"></span>Fast settlement</li>
              </ul>
            </div>
          </div>
        </section>

        <button type="submit" id="place-order-btn" class="btn btn-primary w-full text-base py-5 disabled:opacity-50 disabled:cursor-not-allowed" <%= !locals.plisioEnabled ? 'disabled' : '' %>>
          <span id="place-order-label">Continue to payment <span class="opacity-60 mx-2">·</span> <span id="checkout-grand-total" class="font-mono">$0.00</span></span>
          <span id="place-order-loading" class="hidden"><i data-lucide="loader-2" class="w-4 h-4 animate-spin"></i> Generating invoice…</span>
        </button>
        <p id="checkout-error" class="text-[0.85rem] text-rose mt-3 hidden"></p>

        <p class="text-[0.78rem] text-ink-4 mt-5 leading-relaxed">
          By placing this order you confirm research-use intent and acknowledge our
          <a href="/legal/disclaimer" class="link-underline">RUO terms</a> and
          <a href="/legal/shipping" class="link-underline">shipping policy</a>. Products are not for human consumption.
        </p>
      </form>
    </div>

    <aside class="col-span-12 lg:col-span-3 lg:sticky lg:top-28 lg:self-start order-first lg:order-none">
      <div class="border border-ink p-6 bg-paper">
        <div class="flex items-center justify-between mb-5">
          <p class="kicker">Order summary</p>
          <button type="button" id="summary-toggle" class="kicker text-ink-3 hover:text-ink lg:hidden">Hide</button>
        </div>
        <div id="summary-collapsible">
          <div id="checkout-line-items" class="max-h-72 overflow-y-auto"></div>
          <dl class="rule-t mt-4 pt-4 space-y-2.5 text-[0.9rem]">
            <div class="flex justify-between"><dt class="text-ink-3">Subtotal</dt><dd id="checkout-subtotal" class="font-mono">$0.00</dd></div>
            <div class="flex justify-between"><dt class="text-ink-3" id="checkout-shipping-label">Shipping</dt><dd id="checkout-shipping" class="font-mono text-ink-4">—</dd></div>
            <div class="flex justify-between font-display text-[1.3rem] font-medium pt-3 mt-3 rule-t"><dt>Total</dt><dd id="checkout-total" class="font-mono">$0.00</dd></div>
          </dl>

          <div id="free-shipping-mount" class="mt-5"></div>

          <ul class="mt-6 pt-5 rule-t space-y-2 text-[0.7rem] font-mono uppercase tracking-wider text-ink-4">
            <li><span class="dot dot-emerald mr-2"></span>EU dispatch · 2–7 days</li>
            <li><span class="dot dot-emerald mr-2"></span>Plain unmarked outer</li>
            <li><span class="dot dot-emerald mr-2"></span>COA per batch</li>
            <li><span class="dot dot-emerald mr-2"></span>Crypto-only · privacy-respecting</li>
          </ul>
        </div>
      </div>
    </aside>

  </div>

  <div id="mobile-cta-bar" class="checkout-summary-bar is-mobile lg:hidden hidden">
    <div class="flex items-center justify-between gap-4 max-w-editorial mx-auto">
      <div>
        <p class="kicker text-ink-4">Total</p>
        <p class="font-mono text-[1.1rem] font-medium" id="mobile-total">$0.00</p>
      </div>
      <button type="button" id="mobile-place-trigger" class="btn btn-primary px-6 py-3 text-sm" <%= !locals.plisioEnabled ? 'disabled' : '' %>>Continue →</button>
    </div>
  </div>

</main>

<script id="shipping-data" type="application/json"><%- JSON.stringify({ zones: shippingZones, options: shippingOptions, freeShippingThreshold }) %></script>

<%- include('partials/cart-drawer') %>
<%- include('partials/footer') %>
<%- include('partials/scripts') %>
